classDiagram
    class Owner {
        +str name
        +int daily_minutes
        +list~Pet~ pets
        +add_pet(pet: Pet) void
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task: Task) void
    }

    class Task {
        +str name
        +int duration
        +Priority priority
        +edit(name, duration, priority) void
    }

    class Priority {
        <<enumeration>>
        LOW
        MEDIUM
        HIGH
    }

    class Scheduler {
        +generate(owner: Owner) Schedule
    }

    class Schedule {
        +list~Task~ items
        +int total_minutes
        +display() str
    }

    Owner "1" *-- "*" Pet : owns
    Pet "1" *-- "*" Task : has
    Task --> Priority : uses
    Scheduler ..> Owner : reads
    Scheduler ..> Schedule : produces
    Schedule "1" o-- "*" Task : contains
